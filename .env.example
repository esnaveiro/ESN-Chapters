# ESN Chronicle — Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to Git

# ── Section branding ───────────────────────────────────────────
# Your section's name — used in the nav, page title, hero text, and admin panel.
# Example: "ESN Aveiro", "ESN Porto", "ESN Coimbra"
NEXT_PUBLIC_SECTION_NAME="ESN Section"

# ── Database ───────────────────────────────────────────────────
# Supabase Dashboard → Settings → Database → Connection string → URI

# Transaction mode (port 6543) — used by the app at runtime (serverless-safe)
DATABASE_URL=""

# Session mode (port 5432) — used by Prisma migrations only
DIRECT_URL=""

# ── Supabase ───────────────────────────────────────────────────
# Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=""

# Supabase Dashboard → Settings → API → anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Supabase Dashboard → Settings → API → service_role key
# Used server-side only for admin operations (inviting users)
# NEVER expose this in client-side code or public env vars
SUPABASE_SERVICE_ROLE_KEY=""
